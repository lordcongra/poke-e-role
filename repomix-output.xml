                };
            } else {
                mergedItems.push({
                    ...item,
                    id: crypto.randomUUID(),
                    pocket: guaranteedPocket,
                    category: guaranteedCategory
                });
            }
        });

        set({
            roomCustomTypes: mergedTypes,
            roomCustomAbilities: mergedAbilities,
            roomCustomMoves: mergedMoves,
            roomCustomPokemon: mergedPokemon,
