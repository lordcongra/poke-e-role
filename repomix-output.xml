        gmHpBar: boolean;
        settingHpText: boolean;
        gmHpText: boolean;
        settingWillBar: boolean;
        gmWillBar: boolean;
        settingWillText: boolean;
        gmWillText: boolean;
        settingDefBadge: boolean;
        gmDefBadge: boolean;
        settingEcoBadge: boolean;
        gmEcoBadge: boolean;
