    acc1Options?: string[];
    acc2Options?: string[];
    dmg1Options?: string[];
}

export interface PrintConfig {
    blankName: boolean;
    blankSpecies: boolean;
    blankType: boolean;
    blankNature: boolean;
    blankRank: boolean;
    blankAgeGender: boolean;
    blankStats: boolean;
    blankSocials: boolean;
