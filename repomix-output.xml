    "sharp beak": "[Dmg +1: Flying]", "silk scarf": "[Dmg +1: Normal]",
    "silver powder": "[Dmg +1: Bug]", "soft sand": "[Dmg +1: Ground]",
    "spell tag": "[Dmg +1: Ghost]", "twisted spoon": "[Dmg +1: Psychic]",
    "razor claw": "[High Crit]", "leek": "[High Crit]",
