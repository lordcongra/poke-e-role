    }

    .print-sheet__stat-value-container {
        display: flex;
        align-items: center;
        gap: 6px;
    }

    .print-sheet__dots {
        font-size: 1.4rem;
        letter-spacing: 1px;
        color: black;
        line-height: 0.8;
    }

    .print-sheet__number {
        font-size: 0.9rem;
        font-weight: bold;
