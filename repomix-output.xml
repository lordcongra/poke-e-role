            </td>
            <td className="data-table__cell--middle">
                <div className="flex-layout--row-center">
                    <NumberSpinner
                        value={data.buff}
                        onChange={(value: number) => setSkill(skill, 'buff', value)}
                        min={0}
                    />
                </div>
            </td>
            <td className="data-table__cell--middle skill-row__total-cell">{total}</td>
        </tr>
    );
}
