    updateStatus: <K extends keyof StatusItem>(id: string, field: K, value: StatusItem[K]) => void;
    removeStatus: (id: string) => void;
    addEffect: () => void;
    updateEffect: <K extends keyof EffectItem>(id: string, field: K, value: EffectItem[K]) => void;
