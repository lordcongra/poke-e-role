/* =========================================
   🌙 DARK MODE COLOR MUTING
   ========================================= */
[data-theme='dark'] .identity-grid__label--blue {
    background: #0d47a1;
    color: #bbdefb;
}
[data-theme='dark'] .identity-grid__label--green {
    background: #1a5e20;
    color: #dcedc8;
}
