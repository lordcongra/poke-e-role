    }
    .health-section__box {
        flex: 1 1 100% !important;
        min-width: 100%;
        margin-top: 4px;
    }
    .action-button {
        padding: 8px !important;
        font-size: 0.95rem !important;
        min-height: 40px;
    }
    input.sheet-save,
    select.sheet-save {
        padding: 6px 4px !important;
        font-size: 0.95rem !important;
        min-height: 36px;
    }
}
