    /* --- Dots & Numbers --- */
    .print-sheet__stat-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 4px;
    }

    .print-sheet__stat-name {
        font-size: 0.85rem;
        font-weight: bold;
